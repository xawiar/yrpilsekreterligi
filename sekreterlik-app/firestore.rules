rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admin/main) &&
        get(/databases/$(database)/documents/admin/main).data.uid == request.auth.uid;
    }

    // Coordinator role'lerinden biri mi? (admin / provincial / district /
    // region / institution_supervisor). Sandık atama, bölge tanımı gibi
    // hassas yetkili işlemler için.
    function isCoordinator() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/member_users/$(request.auth.uid)) &&
        (
          get(/databases/$(database)/documents/member_users/$(request.auth.uid)).data.userType == 'admin' ||
          get(/databases/$(database)/documents/member_users/$(request.auth.uid)).data.userType == 'coordinator' ||
          get(/databases/$(database)/documents/member_users/$(request.auth.uid)).data.coordinatorId != null ||
          get(/databases/$(database)/documents/member_users/$(request.auth.uid)).data.coordinator_id != null
        );
    }

    // Bildirim doc id'si memberId/coordinatorId/observerId/auth.uid olabilir.
    // Caller'ın member_users doc'undan bu alanlarla eşleşme kontrol et.
    function isOwnNotification(userId) {
      return isAuthenticated() && (
        request.auth.uid == userId ||
        (
          exists(/databases/$(database)/documents/member_users/$(request.auth.uid)) &&
          (
            get(/databases/$(database)/documents/member_users/$(request.auth.uid)).data.memberId == userId ||
            get(/databases/$(database)/documents/member_users/$(request.auth.uid)).data.coordinatorId == userId ||
            get(/databases/$(database)/documents/member_users/$(request.auth.uid)).data.observerId == userId ||
            get(/databases/$(database)/documents/member_users/$(request.auth.uid)).id == userId
          )
        )
      );
    }

    // Admin settings - authenticated can read, admin can write
    // First-time setup: admin/main can only be created if it doesn't already exist
    match /admin/{document} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && !exists(/databases/$(database)/documents/admin/main);
      allow update, delete: if isAdmin();
    }

    // Push tokens — authenticated users can save their own token
    // Anonim ziyaretciler "anon_*" doc id'siyle kendi token'larini olusturabilir/guncelleyebilir
    // (push aboneligi icin gerekli — landing page banner)
    match /push_tokens/{tokenId} {
      allow read: if isAuthenticated();
      // Anonim create + update: doc id 'anon_' ile basliyorsa ve isAnonymous=true ise
      allow create: if (isAuthenticated() && request.auth.uid != null) ||
        (tokenId.matches('anon_.*') && request.resource.data.isAnonymous == true);
      allow update: if (isAuthenticated() && request.auth.uid != null) ||
        (tokenId.matches('anon_.*') && request.resource.data.isAnonymous == true);
      allow delete: if isAuthenticated() && (request.auth.uid == tokenId || isAdmin());
    }

    // FCM tokens
    match /fcm_tokens/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // FCM notification queue — system write
    match /fcm_notification_queue/{docId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // Members - public read (landing page için gerekli), write sadece admin/başkan
    // Hassas alanlar frontend'de `safeMember` helper'ı ile filtrelenir.
    match /members/{memberId} {
      allow read: if true;
      allow create: if isAdmin() ||
        (isAuthenticated() && request.auth.token.role in ['district_president', 'town_president']);
      allow update: if isAdmin() ||
        (isAuthenticated() && request.auth.token.role in ['district_president', 'town_president']) ||
        (isAuthenticated() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['photo', 'biography', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // Member users - read public (login flow için gerekli), write admin only
    // NOT: Şifreler zaten encryptData ile şifrelenmiş saklanır. Login akışı
    // (başmüşahit, sorumlu, üye) authenticate olmadan member_users'ı okumak
    // zorunda — bu yüzden read public. İleride Cloud Function ile
    // güvenli login mantığına taşınabilir.
    match /member_users/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Meetings, Events - admin and presidents can write
    match /meetings/{meetingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() ||
        (isAuthenticated() && request.auth.token.role in ['district_president', 'town_president']);
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() ||
        (isAuthenticated() && request.auth.token.role in ['district_president', 'town_president']);
    }

    // Districts - public read required: PublicApplicationPage.jsx fetches districts
    // from Firestore without auth for the membership application form dropdown.
    // Do NOT change to isAuthenticated() — it would break the public application form.
    match /districts/{districtId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Towns / Neighborhoods / Villages - public read (cascade dropdown for application form)
    match /towns/{townId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /neighborhoods/{nbId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /villages/{villageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Membership applications - public create, admin read/update
    match /membership_applications/{applicationId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Master notifications - admin only
    // (Üye-üye spam'ı engellemek için create de admin'e kısıtlandı)
    match /master_notifications/{notifId} {
      allow create: if isAdmin();
      allow read, update, delete: if isAdmin();
    }

    // Notifications - owner read, admin write, authenticated create for system notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        (resource.data.memberId == request.auth.uid || resource.data.memberId == null);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (resource.data.memberId == request.auth.uid || resource.data.memberId == null);
      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.memberId == request.auth.uid);
    }

    // Personal documents - owner + admin
    match /personal_documents/{docId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.memberId == request.auth.uid);
      allow write: if isAdmin();
    }

    // Secimler - public read (secim sonuclari sayfasi icin gerekli)
    match /elections/{electionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Sandiklar - public read; yazım sadece admin (kötü niyetli kullanıcı
    // sandık konumunu değiştiremesin). ElectionPreparationPage AdminRoute
    // korumalı — sadece admin erişebilir. secim-sandik projesinden uyarlandı.
    match /ballot_boxes/{boxId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Sandik musahitleri - public read; yazım sadece admin (atama hassas).
    // ObserversPage AdminRoute korumalı.
    match /ballot_box_observers/{observerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Sandık başına yüklenen evraklar (tutanak fotoğrafları, itiraz tutanakları, diğer)
    // SIKILAŞTIRILDI:
    //  - Read: authenticated (UI tarafında scope filtreleme var)
    //  - Create/Update: authenticated AMA ballot_box_id'si kendi sandığı olmalı
    //    (chief_observer için; sorumlular ve admin için cloud function kullanılır)
    //  - Delete: sadece admin
    match /ballot_box_documents/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() ||
        (isAuthenticated() &&
          exists(/databases/$(database)/documents/member_users/$(request.auth.uid)) &&
          (
            get(/databases/$(database)/documents/member_users/$(request.auth.uid)).data.ballotBoxId == request.resource.data.ballot_box_id ||
            get(/databases/$(database)/documents/member_users/$(request.auth.uid)).data.ballot_box_id == request.resource.data.ballot_box_id
          )
        );
      allow delete: if isAdmin();
    }

    // Sorumlular (coordinator'lar) — login akışı için public read.
    // SIKILAŞTIRILDI: write sadece admin (sorumlu atama hassas yetki).
    match /election_coordinators/{coordinatorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bölgeler — sorumlu dashboard'ı login öncesi okumaz ama coordinator
    // bilgisinin tutarlı görünümü için aynı seviyede public read
    // SIKILAŞTIRILDI: write sadece admin (sorumlu yetki kontrolünün temeli —
    // biri bunu değiştirirse başka sorumlunun yazma yetkisi yapay genişler).
    match /election_regions/{regionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Eğitim materyalleri — public read (anonim ziyaretçiler de erişir),
    // SIKILAŞTIRILDI: write sadece admin (sahte materyal upload riski).
    match /training_materials/{materialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Eğitim tamamlama kayıtları — kullanıcı kendi kaydını yazabilir,
    // admin tüm kayıtları okur. Doc id format: `${userId}_${materialId}`
    match /training_completions/{completionId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Secim ziyaretci takibi - anonim read/write (visitor tracking)
    match /election_visitors/{visitorId} {
      allow read, write: if true;
    }

    // Election results - halka açık okuma (sonuç yayınları için).
    // SIKILAŞTIRILDI: write sadece admin (cloud function admin SDK kullanıyor → geçer).
    // Client doğrudan yazamaz; submitElectionResult cloud function üzerinden gider,
    // function rol+zincir kontrolü yapar (chief_observer kendi sandığı, coordinator
    // kapsamı, admin tümü).
    match /election_results/{resultId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public election cache — aggregate edilmiş seçim sonuçları.
    // SIKILAŞTIRILDI: write sadece admin.
    match /public_election_cache/{cacheId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Meeting RSVP - authenticated users can read/write their own
    match /meeting_rsvp/{rsvpId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Polls - authenticated read, admin create/delete
    match /polls/{pollId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      allow update: if isAuthenticated();
    }

    match /poll_votes/{voteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // AI config - admin only
    match /groq_api_config/{doc} {
      allow read, write: if isAdmin();
    }
    match /gemini_api_config/{doc} {
      // Giriş yapmış tüm kullanıcılar okuyabilir (OCR servisi için key lazım).
      // Key zaten .env fallback olarak client bundle'ında, ekstra risk değil.
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /chatgpt_api_config/{doc} {
      allow read, write: if isAdmin();
    }
    match /deepseek_api_config/{doc} {
      allow read, write: if isAdmin();
    }
    match /sms_config/{doc} {
      allow read, write: if isAdmin();
    }

    // Notification preferences — userId burada da Auth uid değil olabilir.
    // GERİ ALINDI: authenticated yeter (kötü niyet senaryosu zayıf).
    match /notification_preferences/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // User notifications — subcollection items
    // NOT: userId = member.id (Firestore member doc id), Auth UID değil.
    // Bu yüzden request.auth.uid == userId koşulu işe yaramaz; üye kendi
    // bildirimlerini okumak/silmek/işaretlemek için authentication yeterli.
    // (Üye her durumda sadece kendi memberId'sine ait bildirimleri açar.)
    match /user_notifications/{userId}/items/{itemId} {
      allow read, create, update, delete: if isAuthenticated();
    }
    // GERİ ALINDI: userId burada memberId (Firestore doc id), Auth uid'inden
    // farklı olabilir → owner-match çalışmıyor, listener kırılıyordu.
    // Tam owner kontrolü cloud function ile yapılana kadar authenticated yeter.
    match /user_notifications/{userId} {
      allow read, write: if isAuthenticated();
      match /items/{itemId} {
        allow read, write: if isAuthenticated();
      }
    }

    // App settings (branding, theme, etc.)
    match /app_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{docId} {
      // Public read — landing page tema/branding'i anonim ziyaretçilere de uygulanır
      allow read: if true;
      allow write: if isAdmin();
    }

    // Performance score config
    match /performance_score_config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Member dashboard analytics — authenticated users can write their own sessions
    match /member_dashboard_analytics/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Audit logs - authenticated kullanıcılar okuyabilir (işlem geçmişi UI için).
    // Sorumlu/başmüşahit kendi sandığının log'larını görür; admin tüm log'lara
    // erişir. Filtreleme uygulama tarafında entity_id ile yapılır.
    match /audit_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Profil değişiklik talepleri (TC/telefon)
    match /profile_update_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Talep / Şikayet / İstek / Soru + mesaj thread'leri
    match /requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if false;
      }
    }

    // Başvuru kampanyaları (admin açar, herkes okur)
    // İstisna: üye başvuru gönderirken submissionCount sayacını artırabilir
    match /applications/{applicationId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        (isAuthenticated() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['submissionCount', 'updatedAt']));
    }

    // Başvurular (üye gönderir, admin onaylar/ret)
    match /application_submissions/{submissionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Landing page içeriği — public read, admin + yetkili üye write
    // Yetki kontrolü UI'da manage_landing_page üzerinden yapılır.
    match /landing_content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Landing page haberler/duyurular — public read, authenticated write (UI-gated)
    match /landing_news/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Landing page galeri — public read, authenticated write (UI-gated)
    match /landing_gallery/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Seçmen listesi (YSK CSV import) — authenticated read, admin write
    match /voters/{voterId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Catch-all for any other collections — authenticated read, admin write
    // Also covers subcollections with {sub=**} wildcard
    match /{collection}/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /{collection}/{docId}/{sub=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
