rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admin/main) &&
        get(/databases/$(database)/documents/admin/main).data.uid == request.auth.uid;
    }

    // Admin settings - admin only
    match /admin/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Members - admin write, authenticated read
    match /members/{memberId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() ||
        (isAuthenticated() && request.auth.token.role in ['district_president', 'town_president']);
      allow delete: if isAdmin();
    }

    // Member users - admin only (contains credentials)
    match /member_users/{userId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.authUid == request.auth.uid);
      allow write: if isAdmin();
    }

    // Meetings, Events - admin and presidents can write
    match /meetings/{meetingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() ||
        (isAuthenticated() && request.auth.token.role in ['district_president', 'town_president']);
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() ||
        (isAuthenticated() && request.auth.token.role in ['district_president', 'town_president']);
    }

    // Districts - public read for application form dropdown, admin write
    match /districts/{districtId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Membership applications - public create, admin read/update
    match /membership_applications/{applicationId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Master notifications - admin read/write, public create for system events
    match /master_notifications/{notifId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Notifications - owner read, admin write, public create for system notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        (resource.data.memberId == request.auth.uid || resource.data.memberId == null);
      allow create: if true;
      allow update: if isAuthenticated() &&
        (resource.data.memberId == request.auth.uid || resource.data.memberId == null);
      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.memberId == request.auth.uid);
    }

    // Personal documents - owner + admin
    match /personal_documents/{docId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.memberId == request.auth.uid);
      allow write: if isAdmin();
    }

    // Election results - admin + coordinators can write
    match /election_results/{resultId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() ||
        (isAuthenticated() && request.auth.token.role in ['chief_observer', 'provincial_coordinator', 'district_supervisor', 'region_supervisor', 'institution_supervisor']);
    }

    // Meeting RSVP - authenticated users can read/write their own
    match /meeting_rsvp/{rsvpId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Polls - authenticated read, admin create/delete
    match /polls/{pollId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      allow update: if isAuthenticated();
    }

    match /poll_votes/{voteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // AI config - admin only
    match /groq_api_config/{doc} {
      allow read, write: if isAdmin();
    }
    match /gemini_api_config/{doc} {
      allow read, write: if isAdmin();
    }
    match /chatgpt_api_config/{doc} {
      allow read, write: if isAdmin();
    }
    match /deepseek_api_config/{doc} {
      allow read, write: if isAdmin();
    }
    match /sms_config/{doc} {
      allow read, write: if isAdmin();
    }

    // Audit logs - admin only
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Organization data - admin write only, authenticated read
    match /{collection}/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
