rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Members photos - authenticated read, authenticated write with size limit
    match /members/{memberId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Personal documents - authenticated with size limit
    match /personal-documents/{memberId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }

    // Archive documents
    match /archive/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }

    // Election protocol photos
    match /election-protocols/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Default deny for unmatched paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
