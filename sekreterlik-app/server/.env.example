# Server Configuration
PORT=5000
NODE_ENV=development

# Firebase Configuration
VITE_USE_FIREBASE=true
USE_FIREBASE=true

# Firebase Service Account (JSON string)
# Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_KEY=

# Encryption Keys
# Minimum 32 karakter
VITE_ENCRYPTION_KEY=your-encryption-key-minimum-32-characters-long-for-security
# Field-level encryption key (hex format, 64 chars = 32 bytes)
FIELD_ENCRYPTION_KEY=

# JWT Secret (auth middleware icin)
JWT_SECRET=

# VAPID Keys (Push Notifications)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# CORS Allowed Origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# MongoDB (opsiyonel, Firebase kullanilmiyorsa)
MONGODB_URI=mongodb://localhost:27017/sekreterlik_messages

# Sentry Error Tracking (opsiyonel)
# https://sentry.io adresinden DSN alinir
SENTRY_DSN=

# API Base URL (opsiyonel, scripts icin)
API_BASE_URL=http://localhost:5000/api

# Database Maintenance (true/false)
ENABLE_DB_MAINTENANCE=true
